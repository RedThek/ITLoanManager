datasource db {
  provider = "sqlite"
}

generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/sqlite"
}

// Entité Utilisateur (Administrateurs et Étudiants)
model User {
  id        Int      @id @default(autoincrement())
  username  String   @unique
  password  String
  role      String // Géré par la constante stricte UserRoles ('STUDENT' ou 'ADMIN')
  matricule String?  @unique // Obligatoire uniquement pour les étudiants
  createdAt DateTime @default(now())
  loans     Loan[] // Relation un-à-plusieurs : un utilisateur a plusieurs emprunts
}

// Entité Équipement (Inventaire du Laboratoire IT)
model Equipment {
  id        Int      @id @default(autoincrement())
  name      String
  category  String
  status    String // Géré par la constante EquipmentStatus ('En stock', 'Emprunte', etc.)
  createdAt DateTime @default(now())
  loans     Loan[] // Relation un-à-plusieurs : un équipement peut être lié à plusieurs lignes de prêt
}

// Entité Pivot / Transactionnelle de Prêt
model Loan {
  id          Int       @id @default(autoincrement())
  userId      Int // Clé étrangère pointant vers l'utilisateur
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  equipmentId Int // Clé étrangère pointant vers l'équipement
  equipment   Equipment @relation(fields: [equipmentId], references: [id], onDelete: Cascade)
  status      String // Géré par la constante LoanStatus ('En attente', 'Approuve', etc.)
  requestDate DateTime  @default(now())
  actionDate  DateTime? // Date à laquelle l'admin approuve, refuse ou clôture le prêt
}
